# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Публичный URL сайта (нужен для tonconnect-manifest и проверки ton_proof домена)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://tonarena:tonarena@localhost:5432/tonarena?connection_limit=10

# ─── Auth ──────────────────────────────────────────────────────
# 32+ случайных байта в hex/base64: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
ADMIN_JWT_SECRET=change-me-to-another-long-random-secret

# ─── TON ───────────────────────────────────────────────────────
# mainnet | testnet
TON_NETWORK=mainnet
# API-ключ toncenter: https://t.me/tonapibot
TONCENTER_API_KEY=
# 24 слова мнемоники горячего кошелька платформы (ТОЛЬКО через env, никогда не коммитить)
HOT_WALLET_MNEMONIC=

# ─── Limits (nanotons; 1 TON = 1000000000) ─────────────────────
# Выводы выше этого порога требуют одобрения админа
WITHDRAWAL_AUTO_LIMIT=100000000000

# ─── Dev ───────────────────────────────────────────────────────
# true = включает /api/dev/login (тестовый вход без кошелька). НИКОГДА не включать в проде!
ENABLE_DEV_LOGIN=false
