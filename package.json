{
  "name": "ton-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false server/index.ts",
    "build": "next build && tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "start": "cross-env NODE_ENV=production node dist/server/index.js",
    "lint": "eslint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:embedded": "tsx scripts/embedded-postgres.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@tanstack/react-query": "^5.66.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "@tonconnect/ui-react": "^2.0.11",
    "argon2": "^0.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.0.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.475.0",
    "next": "15.5.20",
    "next-intl": "^3.26.0",
    "next-themes": "^0.4.4",
    "pino": "^9.6.0",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.0.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.5.0",
    "tailwindcss": "^4",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
