{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "noEmit": false,
    "jsx": "preserve",
    "allowImportingTsExtensions": false,
    "plugins": []
  },
  "include": ["server/**/*.ts", "src/services/**/*.ts", "src/lib/**/*.ts", "src/types/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "src/**/*.tsx"]
}
